# 生产环境配置
# 复制此文件为 .env 并填入真实的 API Key

# DeepSeek API（用于 LLM 分析）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PaddleOCR 云端 API（用于 OCR）
PADDLEOCR_ACCESS_TOKEN=your_paddleocr_token_here
PADDLEOCR_DOC_PARSING_API_URL=https://paddleocr.com/layout-parsing
PADDLEOCR_DOC_PARSING_TIMEOUT=600
